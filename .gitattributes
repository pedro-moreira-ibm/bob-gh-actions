# Normalise all text files to LF in the repository.
# This ensures shell scripts and TOML files checked out on
# Linux GitHub Actions runners always have Unix line endings.
* text=auto eol=lf

# Explicitly enforce LF for files consumed by bash on runners
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
